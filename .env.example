# PostgreSQL — Prisma uses DATABASE_URL at runtime and DIRECT_URL for migrations (e.g. Vercel build).
# For local dev (Docker example in README), Homebrew Postgres, etc., set both to the same URL:
#
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dash"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/dash"
#
# Managed hosts (Neon, Vercel Postgres, RDS, …): use the connection strings they provide. If the host
# gives you a pooler URL plus a “direct” or “session” URL for migrations, use pooler → DATABASE_URL
# and direct → DIRECT_URL; otherwise set both to the same URL.
#
# Neon on Vercel: if Prisma fails during deploy with P1002 / pg_advisory_lock timeout, DATABASE_URL is
# usually the *pooler* URL and DIRECT_URL must be the *direct* (non-pooler) URL — both from Neon’s UI.
# Optional on slow wake-ups: append ?sslmode=require&connect_timeout=60 (Neon may already include sslmode).

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Comma-separated Workspace emails to seed the To-dos assignee menu (optional; also learns from history).
# TODO_ASSIGNEE_EMAILS="you@example.com,partner@example.com"

# Slack notifications (ticket movement)
# Create an "Incoming Webhook" app in Slack, then paste the webhook URL here.
# If unset, no Slack notifications will be sent.
# No extra quotes inside the value (or strip them — the app normalizes "'https://...'" and "https://...").
SLACK_WEBHOOK_URL=""
# Optional. Empty = on when URL is set. Only 1/true/yes/on turns it on if you set this at all; use 0/false/off to disable.
SLACK_NOTIFICATIONS_ENABLED="1"
# Optional: override bot display name / icon for webhook posts.
# SLACK_WEBHOOK_USERNAME="Dash"
# SLACK_WEBHOOK_ICON_EMOJI=":gear:"
# Production workflow (Start / Ready / Delivered) — optional:
# SLACK_PRODUCTION_MENTION="<!subteam^S01234567>"   # line prepended to production pings (Slack user group ID format)
# SLACK_PRODUCTION_STATUSES="IN_PROGRESS"           # only notify when status is in this list; omit = all production changes
# SLACK_WEBHOOK_ENV="production"                    # only send webhooks on Vercel Production (skip local + Preview)
# SLACK_NOTIFY_ARCHIVE="0"                          # omit Done/Lost archive pings; production pings unchanged

# Auth (Google Workspace login)
# REQUIRED on Vercel (Production + Preview if you test sign-in there). Without it, NextAuth logs NO_SECRET and /api/auth/* returns 500.
# Generate: `openssl rand -base64 32`
NEXTAUTH_SECRET="replace-me"
# Must match the URL users open in production (https, no trailing slash), e.g. https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"
# Sign-in is restricted to this Google Workspace domain (default beseensignshop.com if unset).
# GOOGLE_WORKSPACE_DOMAIN="beseensignshop.com"
#
# Google Cloud → Credentials → OAuth 2.0 Web client → Authorized redirect URIs — add ALL of these for this app:
#   {NEXTAUTH_URL}/api/auth/callback/google     ← required for "Sign in with Google" (often missed if you only added Gmail)
#   {origin}/api/integrations/gmail/callback
#   {origin}/api/integrations/google-business/callback   (if you use GBP connect)
# Use the same GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET here as for Gmail below.

# Dash Manager (optional — /dashboard/assistant). Server-side only; never expose in NEXT_PUBLIC_*.
# OPENAI_API_KEY=""
# Optional model id (default gpt-4o-mini).
# OPENAI_MODEL="gpt-4o-mini"

# External profiles (sidebar Integrations — optional; defaults are generic home URLs)
# Yelp for Business (owner dashboard — listings, leads, ads)
# NEXT_PUBLIC_YELP_URL="https://biz.yelp.com"
# Open the metrics / performance screen you use in Yelp for Business, copy the URL, set here for a direct sidebar jump:
# NEXT_PUBLIC_YELP_INSIGHTS_URL="https://biz.yelp.com/..."
# Google Business Profile — hub (listings / edit). Default is the signed-in dashboard, not the marketing home page.
# NEXT_PUBLIC_GOOGLE_BUSINESS_URL="https://business.google.com/dashboard"
# Performance & analytics: Google has no one URL for all accounts. Open "Performance" in GBP, copy your browser URL, paste here:
# NEXT_PUBLIC_GOOGLE_BUSINESS_INSIGHTS_URL="https://business.google.com/..."
# NEXT_PUBLIC_FACEBOOK_URL="https://www.facebook.com/"
# NEXT_PUBLIC_INSTAGRAM_URL="https://www.instagram.com/"
QUICKBOOKS_ENVIRONMENT="sandbox"
# Optional. IANA timezone for Profit and Loss month-to-date (month start through "today" in this zone).
# QUICKBOOKS_REPORT_TIMEZONE="America/Los_Angeles"
# P&L on Accounting page: Accrual (default) or Cash
# QUICKBOOKS_PNL_ACCOUNTING_METHOD="Accrual"
QUICKBOOKS_WEBHOOK_VERIFIER="replace-me"
QUICKBOOKS_CLIENT_ID="replace-me"
QUICKBOOKS_CLIENT_SECRET="replace-me"
# Optional. If unset, OAuth uses the host you open + /api/integrations/quickbooks/callback (recommended for local dev).
# QUICKBOOKS_REDIRECT_URI="http://localhost:3000/api/integrations/quickbooks/callback"

# Gmail (optional — full thread + attachment sync on tickets)
GOOGLE_CLIENT_ID="replace-me.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="replace-me"
# Optional. If unset, redirect URL is built from the host you open (e.g. localhost:3000).
# In Google Cloud, register every URI you use, e.g. both localhost and 127.0.0.1:
# GOOGLE_REDIRECT_URI="http://localhost:3000/api/integrations/gmail/callback"
#
# Google Drive (optional — move job folders when ticket status changes). After setting folder IDs, enable
# "Google Drive API" on the same Google Cloud project as Gmail and reconnect Gmail so the token includes Drive scope.
# Use the Drive folder id from each parent folder URL (…/folders/THIS_PART), from your shared drive:
GOOGLE_DRIVE_ACTIVE_FOLDER_ID="https://drive.google.com/drive/folders/1WDIuN-eiE3hQt6gYh9Y6KZxwk7_gdfpV?usp=drive_link"
GOOGLE_DRIVE_COMPLETED_FOLDER_ID="https://drive.google.com/drive/folders/1bMFmvMjqovWeZpqxM4IRDTw8gaAwixL7?usp=drive_link"
GOOGLE_DRIVE_ARCHIVE_FOLDER_ID="https://drive.google.com/drive/folders/1RwWQFQp7iK-U-UYwY5N6p5wj24HnY2v?usp=drive_link"
# Optional: folder id at the same level as Active/Completed/Archive. We add "Customer name" subfolders with Drive shortcuts pointing at each job folder (jobs still live under the stage buckets). Browse all clients and jobs in one tree without moving files.
# GOOGLE_DRIVE_CUSTOMER_HUB_FOLDER_ID=""
# Optional: id of your job folder template (folder only; not a full URL). Enables “Create folder from template” on tickets.
# GOOGLE_DRIVE_JOB_FOLDER_TEMPLATE_ID=""
#
# Google Business Profile API (Settings → Connect Google Business Profile). Same OAuth client as Gmail; add redirect:
# https://YOUR_HOST/api/integrations/google-business/callback
# Enable in Google Cloud → APIs: "Google Business Profile API", "My Business Account Management API",
# "My Business Business Information API", "Business Profile Performance API" (for /dashboard/gbp metrics).
# Optional fixed redirect (otherwise built from request host + path above):
# GOOGLE_REDIRECT_URI_GBP="http://localhost:3000/api/integrations/google-business/callback"
#
# Yelp Fusion (server search/details — get key at https://www.yelp.com/developers )
# YELP_API_KEY=""
