generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProductionStatus {
  NOT_STARTED
  IN_PROGRESS
  READY
  DELIVERED
}

enum BoardStatus {
  REQUESTED
  QUOTED
  APPROVED
  PRODUCTION
  READY
  INVOICED
  DELIVERED
  PAID
}

enum ArchiveReason {
  DONE
  LOST
}

enum EstimateStatus {
  UNKNOWN
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

enum InvoiceStatus {
  NONE
  DRAFT
  OPEN
  PAID
  VOID
}

enum EventSource {
  QUICKBOOKS
  APP
  SYSTEM
}

enum EventProcessStatus {
  RECEIVED
  PROCESSED
  FAILED
}

enum TaskStatus {
  OPEN
  DONE
}

model Job {
  id                   String            @id @default(cuid())
  quickbooksCompanyId  String?
  quickbooksCustomerId String?
  quickbooksEstimateId String?           @unique
  quickbooksInvoiceId  String?           @unique
  customerName         String
  projectName          String
  /// From QBO: CustomerMemo and/or first line Description — human subtitle on cards (not the doc # in projectName).
  projectDescription   String?
  estimateStatus       EstimateStatus    @default(UNKNOWN)
  invoiceStatus        InvoiceStatus     @default(NONE)
  estimateAmountCents  Int               @default(0)
  invoiceAmountCents   Int               @default(0)
  amountPaidCents      Int               @default(0)
  estimateSentAt       DateTime?
  estimateAcceptedAt   DateTime?
  /// QuickBooks MetaData.CreateTime (or txn date) for the estimate — for sorting, not last sync.
  estimateCreatedAtQbo DateTime?
  /// QuickBooks MetaData.CreateTime (or txn date) for the invoice.
  invoiceCreatedAtQbo  DateTime?
  /// Coalesced sort: estimate QBO create, else invoice QBO create (see sync).
  qbOrderingAt         DateTime?
  productionStatus     ProductionStatus  @default(NOT_STARTED)
  startedAt            DateTime?
  readyAt              DateTime?
  deliveredAt          DateTime?
  paidAt               DateTime?
  boardStatus          BoardStatus       @default(REQUESTED)
  archivedAt           DateTime?
  archiveReason        ArchiveReason?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  activityLogs         ActivityLog[]
  linkedEmails         LinkedEmail[]
  /// Gmail thread id (from URL or API) — sync pulls every message + attachments in that thread.
  gmailThreadId        String?
  /// Which connected mailbox to use when calling Gmail API for this ticket (you / partner / contact@, etc.).
  gmailConnectionId    String?
  gmailConnection      GmailConnection? @relation(fields: [gmailConnectionId], references: [id], onDelete: SetNull)
  gmailMessages        GmailSyncedMessage[]
  tasks                Task[]
  /// Google Drive folder for this job (paste folder URL or ID from the shared drive). Used to move the folder when board/archive changes.
  googleDriveFolderId     String?
  /// Last time the folder was confirmed under the correct Active / Completed / Archive parent.
  googleDriveSyncedAt     DateTime?
  /// Last Drive API error (cleared on success) — shown on the ticket for quick debugging.
  googleDriveLastError    String?

  @@index([boardStatus])
  @@index([archivedAt])
  @@index([qbOrderingAt])
}

/// Each Google account you authorize (readonly). Connect yours, your partner’s, and contact@ separately.
model GmailConnection {
  id                     String   @id @default(cuid())
  googleEmail            String   @unique
  refreshToken           String
  accessToken            String
  accessTokenExpiresAt   DateTime
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  jobs                   Job[]
}

/// Google Business Profile API (OAuth scope business.manage) — list accounts/locations, future metrics.
model GoogleBusinessConnection {
  id                     String   @id @default(cuid())
  googleEmail            String   @unique
  refreshToken           String
  accessToken            String
  accessTokenExpiresAt   DateTime
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  /// Last successful { accountCount, locations: { name, title }[] } from GBP APIs (429 / serverless fallback).
  gbpLocationsSnapshot   Json?
  gbpLocationsSnapshotAt DateTime?
}

model Task {
  id             String     @id @default(cuid())
  title          String
  notes          String?
  status         TaskStatus @default(OPEN)
  dueAt          DateTime?
  createdByEmail String

  jobId String?
  job   Job?    @relation(fields: [jobId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, updatedAt])
  @@index([jobId, status])
  @@index([createdByEmail, status])
}

/// Shop-wide to-dos (not ticket-linked; see `Task` for job-related items).
model Todo {
  id             String     @id @default(cuid())
  title          String
  notes          String?
  status         TaskStatus @default(OPEN)
  /// End-of-day or specific instant the item is due (optional).
  dueAt          DateTime?
  /// Google Workspace user expected to do the work; null = unassigned.
  assigneeEmail  String?
  createdByEmail String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([status, dueAt])
  @@index([assigneeEmail, status])
}

model GmailSyncedMessage {
  id             String   @id @default(cuid())
  jobId          String
  job            Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  gmailMessageId String
  gmailThreadId  String
  subject        String?
  fromAddr       String?
  toAddr         String?
  date           DateTime?
  snippet        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  attachments    GmailSyncedAttachment[]

  @@unique([jobId, gmailMessageId])
  @@index([jobId, date])
}

model GmailSyncedAttachment {
  id                String             @id @default(cuid())
  messageId         String
  message           GmailSyncedMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  gmailAttachmentId String
  filename          String
  mimeType          String?
  sizeBytes         Int
  /// Path relative to project root (forward slashes)
  storagePath       String
  createdAt         DateTime           @default(now())

  @@index([messageId])
}

/// User-pasted email thread references (Gmail/Outlook permalinks, mailto, notes). QBO does not expose email threads.
model LinkedEmail {
  id        String    @id @default(cuid())
  jobId     String
  job       Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  subject   String?
  fromAddr  String?
  toAddr    String?
  sentAt    DateTime?
  linkUrl   String?
  notes     String?
  createdAt DateTime  @default(now())

  @@index([jobId, createdAt])
}

model ActivityLog {
  id        String       @id @default(cuid())
  jobId      String
  source     EventSource
  eventName  String
  message    String
  metadata   Json?
  createdAt  DateTime     @default(now())
  job        Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
}

model QuickBooksWebhookEvent {
  id                String              @id @default(cuid())
  providerEventKey  String              @unique
  realmId           String?
  entityType        String
  entityId          String
  operation         String
  payload           Json
  status            EventProcessStatus  @default(RECEIVED)
  errorText         String?
  receivedAt        DateTime            @default(now())
  processedAt       DateTime?
}

/// Stored OAuth tokens after Connect QuickBooks (one row per QBO company / realmId).
model QuickBooksToken {
  id                      String    @id @default(cuid())
  realmId                 String    @unique
  accessToken             String
  refreshToken            String
  accessTokenExpiresAt    DateTime
  refreshTokenExpiresAt   DateTime?
  /// Last successful POST /api/jobs/sync (manual ticket sync from QBO).
  lastTicketSyncAt        DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
}
